{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lovable Solo",
  "version": "1.0.0",
  "identifier": "com.lovable.solo",
  "build": {
    "frontendDist": "../apps/ide/dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "cd apps/ide && bun run dev",
    "beforeBuildCommand": "cd apps/ide && bun run build"
  },
  "app": {
    "windows": [
      {
        "title": "Lovable Solo",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
