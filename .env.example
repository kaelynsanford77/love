# LLM Providers (at least one required)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
OLLAMA_BASE_URL=http://localhost:11434

# Default LLM provider: anthropic | openai | ollama
LLM_PROVIDER=anthropic
LLM_MODEL=claude-3-5-sonnet-20241022

# Auth
BEARER_TOKEN=change-me-in-production

# Ports
IDE_PORT=3000
ORCHESTRATOR_PORT=4000

# Workspaces root (absolute path)
WORKSPACES_ROOT=./workspaces

# Database (optional - for cloud features)
DATABASE_URL=postgresql://lovable:lovable@localhost:5432/lovable

# Sandbox mode: local | docker
SANDBOX_MODE=local

# Caddy (production)
DOMAIN=localhost
BASIC_AUTH_USER=admin
BASIC_AUTH_PASS=changeme

# IDE URL (for previews in production)
VITE_ORCHESTRATOR_URL=http://localhost:4000
VITE_BEARER_TOKEN=
