# ─────────────────────────────────────────────────────────
#  Lovable Solo — Environment Variables
# ─────────────────────────────────────────────────────────

# LLM Provider (Quatarly / OpenAI-compatible)
OPENAI_API_KEY=your-quatarly-key-here
OPENAI_BASE_URL=https://api.quatarly.cloud/v1

# LLM Routing mode: "auto" | "fixed"
LLM_ROUTING=auto
LLM_MODEL_FAST=claude-haiku-4-5-20251001
LLM_MODEL_STANDARD=claude-sonnet-4-6-thinking
LLM_MODEL_POWERFUL=claude-opus-4-6-thinking

# Orchestrator
PORT=4000
HOST=0.0.0.0
WORKSPACES_DIR=./workspaces
SECRETS_ENCRYPTION_KEY=change-me-32-chars-minimum-please

# Postgres (optional)
DATABASE_URL=postgresql://lovable:lovable@localhost:5432/lovable

# GitHub OAuth (optional, for private repo import)
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=

# IDE
VITE_ORCHESTRATOR_URL=http://localhost:4000
