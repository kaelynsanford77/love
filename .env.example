# LLM Provider (Quatarly — OpenAI-compatible)
LLM_PROVIDER=openai
OPENAI_API_KEY=your-quatarly-key
OPENAI_BASE_URL=https://api.quatarly.cloud/v1

# LLM Models
LLM_MODEL_FAST=claude-haiku-4-5-20251001
LLM_MODEL_STANDARD=claude-sonnet-4-6-thinking
LLM_MODEL_POWERFUL=claude-opus-4-6-thinking
LLM_ROUTING=auto

# Auth
BEARER_TOKEN=change-me-in-production

# Ports
IDE_PORT=3000
ORCHESTRATOR_PORT=4000

# Workspaces root (absolute path)
WORKSPACES_ROOT=./workspaces

# Database (optional - for cloud features)
DATABASE_URL=postgresql://lovable:lovable@localhost:5432/lovable

# Sandbox mode: local | docker
SANDBOX_MODE=local

# Caddy (production)
DOMAIN=localhost
BASIC_AUTH_USER=admin
BASIC_AUTH_PASS=changeme

# IDE URL (for previews in production)
VITE_ORCHESTRATOR_URL=http://localhost:4000
VITE_BEARER_TOKEN=
