# AI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1

# Model tiers
LLM_MODEL_FAST=claude-haiku-3-5
LLM_MODEL_STANDARD=claude-sonnet-4-5
LLM_MODEL_POWERFUL=claude-opus-4-5

# Server
PORT=3001
NODE_ENV=development

# Projects storage path
PROJECTS_DIR=/home/runner/work/love/projects

# Frontend URL (for CORS)
WEB_URL=http://localhost:5173

# Database
DB_PATH=./data/love.db

# GitHub (optional)
GITHUB_TOKEN=your_github_token_here

# Supabase (optional)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
