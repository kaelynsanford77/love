{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lovable Solo",
  "version": "1.0.0",
  "identifier": "dev.lovable.solo",
  "build": {
    "beforeDevCommand": "bun run --cwd apps/ide dev",
    "beforeBuildCommand": "bun run --cwd apps/ide build",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../apps/ide/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Lovable Solo",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/icon.icns", "icons/icon.ico"]
  }
}
