# Quatarly / OpenAI-compatible LLM
OPENAI_API_KEY=your-quatarly-api-key-here
OPENAI_BASE_URL=https://api.quatarly.cloud/v1

# LLM Routing (auto or fixed)
LLM_ROUTING=auto
LLM_MODEL_FAST=claude-haiku-4-5-20251001
LLM_MODEL_STANDARD=claude-sonnet-4-6-thinking
LLM_MODEL_POWERFUL=claude-opus-4-6-thinking

# Orchestrator
PORT=3001
NODE_ENV=development

# Security
VAULT_ENCRYPTION_KEY=change-me-32-chars-minimum-here!

# GitHub OAuth (optional)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
